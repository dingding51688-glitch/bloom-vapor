# Default dev proxy: browser hits Next.js /api/strapi, server proxies to STRAPI_DIRECT_URL
# - For local Strapi on port 1337 → set STRAPI_DIRECT_URL=http://127.0.0.1:1337
# - For Cloudflare tunnel → set STRAPI_DIRECT_URL=https://<your-strapi-tunnel>
STRAPI_DIRECT_URL=https://indexes-surrounded-auto-additions.trycloudflare.com
NEXT_PUBLIC_API_BASE_URL=/api/strapi
NEXT_PUBLIC_AUTH_BASE_URL=/api/strapi
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_INTERNAL_BASE_URL=http://localhost:3000
QA_BASE_URL=https://rpg-amendments-camping-coleman.trycloudflare.com

# Optional helper for dev instances where JWT isn't wired yet
NEXT_PUBLIC_API_TOKEN=
NEXT_PUBLIC_DEV_CUSTOMER_ID=
NEXT_PUBLIC_ANALYTICS_KEY=local-analytics-key

# Locker / invoice integrations
NEXT_PUBLIC_LOCKER_API_URL=
NEXT_PUBLIC_LOCKER_API_TOKEN=

# Wallet / top-up helper values (update with real ops data)
NEXT_PUBLIC_BANK_ACCOUNT_NAME="GreenHub Processing Ltd"
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=00000000
NEXT_PUBLIC_BANK_SORT_CODE=00-00-00
NEXT_PUBLIC_TOPUP_USDT_ADDRESS=TBD-USDT-ADDRESS
NEXT_PUBLIC_TOPUP_USDT_QR=
